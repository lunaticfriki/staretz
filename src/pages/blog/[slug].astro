---
import { getCollection, render } from "astro:content";
import Layout from "../../core/ui/layouts/Layout.astro";
import { DependencyLocator } from "../../core/di/DependencyLocator";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { astroPost: post },
  }));
}

const { astroPost } = Astro.props;
const readService = DependencyLocator.getPostReadService();

const post = await readService.getPostById(astroPost.id);

if (!post) {
  throw new Error("Post not found");
}

const { Content } = await render(astroPost);
---

<Layout title={post.title.value}>
  <article class="relative flex flex-col items-center w-full">
    <div class="mb-8 mt-2 w-full max-w-3xl px-4 lg:px-0 z-10">
      <a
        href="/"
        class="text-brand hover:opacity-80 flex items-center gap-2 font-bold transition-all w-fit group text-lg tracking-wider"
      >
        <svg
          class="w-5 h-5 group-hover:-translate-x-1 transition-transform crisp-edges"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="square"
        >
          <path d="M11 19l-7-7 7-7M4 12h16"></path>
        </svg>
        Tornar
      </a>
    </div>

    <div
      class="absolute -top-12 left-0 right-0 w-full h-[60vh] -z-10 pointer-events-none"
    >
      <img
        src={post.heroImage?.value}
        alt={post.title.value}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40 dark:bg-black/20"></div>
      <div
        class="absolute inset-x-0 bottom-0 h-32 md:h-48 bg-gradient-to-t from-[#000000] dark:from-[#000000] to-transparent"
      >
      </div>
    </div>

    <div class="w-full max-w-3xl px-4 lg:px-0 pt-[35vh]">
      <header class="mb-12 w-full text-left">
        <h1
          class="text-5xl font-bold mb-4 w-full [text-shadow:0_4px_10px_rgba(0,0,0,0.8)]"
        >
          {post.title.value}
        </h1>
        <p class="text-brand font-bold text-xl mb-2">
          {post.author.value}
        </p>
        <p
          class="text-gray-500 dark:text-gray-400 text-lg uppercase tracking-widest"
        >
          {post.date.value.toDateString()}
        </p>
      </header>

      <div
        class="prose dark:prose-invert prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-headings:text-[#ff00ff] prose-a:text-[#ff00ff] max-w-none text-xl leading-loose font-sans"
      >
        <div class="pb-8"></div>
        <Content />
      </div>
    </div>
  </article>
</Layout>
