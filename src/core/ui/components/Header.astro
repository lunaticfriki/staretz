---
---

<header
  class="border-b border-gray-200 dark:border-gray-800 p-4 flex justify-between items-end"
>
  <div>
    <a href="/" class="hover:opacity-80 transition-opacity block py-1">
      <img
        src="/logo-name-white.jpg"
        alt="Staretz Blog Logo"
        class="h-6 dark:hidden"
      />
      <img
        src="/logo-name-black.jpg"
        alt="Staretz Blog Logo"
        class="h-6 hidden dark:block"
      />
    </a>
  </div>
  <nav class="flex gap-6 items-center">
    <a
      href="/"
      class="hover:underline text-gray-600 dark:text-gray-300 transition-colors"
      >Home</a
    >
    <a
      href="/about"
      class="hover:underline text-gray-600 dark:text-gray-300 transition-colors"
      >Info</a
    >
    <button
      id="themeToggle"
      class="ml-4 p-2 rounded-none border-2 border-transparent hover:border-brand transition-colors focus:outline-none cursor-pointer"
      aria-label="Toggle dark mode"
    >
      <svg
        class="w-6 h-6 hidden dark:block text-brand"
        viewBox="0 0 14 14"
        shape-rendering="crispEdges"
      >
        <path
          fill="currentColor"
          d="M6 0h2v2H6V0zm0 12h2v2H6v-2zM0 6h2v2H0V6zm12 0h2v2h-2V6zM3 3h2v2H3V3zm6 6h2v2H9V9zM3 9h2v2H3V9zm6-6h2v2H9V3zM5 5h4v4H5V5z"
        ></path>
      </svg>
      <svg
        class="w-6 h-6 block dark:hidden text-brand"
        viewBox="0 0 14 14"
        shape-rendering="crispEdges"
      >
        <path
          fill="currentColor"
          d="M4 1h4v2h2v2h1v4h-1v2h-2v2H4v-2h2v-2h1V5h-1V3H4V1z"></path>
      </svg>
    </button>
  </nav>
</header>
